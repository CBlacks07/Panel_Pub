{
  "expo": {
    "name": "Boutiki",
    "slug": "boutiki",
    "scheme": "boutiki",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#34adea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.panelpub.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pour voir les boutiques proches de vous."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.panelpub.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d65b7d35-2f2d-49fa-83b1-f596e721e429"
      }
    }
  }
}
